{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "agents": {
    "hephaestus": {
      "model": "zai-coding-plan/glm-5"
    },
    "oracle": {
      "model": "regolo/qwen3.5-122b"
    },
    "librarian": {
      "model": "regolo/qwen3.5-122b"
    },
    "explore": {
      "model": "zai-coding-plan/glm-4.7-flash"
    },
    "multimodal-looker": {
      "model": "regolo/qwen3-coder-next"
    },
    "prometheus": {
      "model": "zai-coding-plan/glm-5"
    },
    "metis": {
      "model": "regolo/qwen3.5-122b"
    },
    "momus": {
      "model": "regolo/qwen3-coder-next"
    },
    "sisyphus": {
      "model": "regolo/qwen3-coder-next"
    },
    "atlas": {
      "model": "regolo/qwen3.5-122b"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "zai-coding-plan/glm-5"
    },
    "ultrabrain": {
      "model": "regolo/qwen3.5-122b"
    },
    "deep": {
      "model": "zai-coding-plan/glm-5"
    },
    "artistry": {
      "model": "regolo/gpt-oss-120b"
    },
    "quick": {
      "model": "regolo/qwen3-coder-next"
    },
    "git": {
      "model": "regolo/qwen3-coder-next"
    },
    "deep": {
      "model": "zai-coding-plan/glm-5"
    },
    "writing": {
      "model": "regolo/gpt-oss-120b"
    }
  },
  "experimental": {
    "aggressive_truncation": true,
    "auto_resume": true,
    "preemptive_compaction_threshold": 0.75
  },
  "disabled_skills": ["playwright", "git-master"],
  "background_task": {
    "defaultConcurrency": 10,
    "staleTimeoutMs": 180000,
    "modelConcurrency": {
      "zai-coding-plan/glm-5": 2,
      "zai-coding-plan/glm-4.7-flash": 1,
      "regolo/qwen3.5-122b": 5,
      "regolo/qwen3-coder-next": 10,
      "regolo/gpt-oss-120b": 5,
    }
  },
  "notification": {
    "force_enable": true
  },
  "hashline_edit": true,
  "disabled_hooks": ["non-interactive-env"]
}
